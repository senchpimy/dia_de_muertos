{
  "rewrites": [
    {
      "source": "/",
      "destination": "/docs/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/docs/$1"
    }
  ],
  "headers": [
    {
      "source": "/Build/(.*).gz",
      "headers": [
        { "key": "Content-Encoding", "value": "gzip" }
      ]
    },
    {
      "source": "/Build/(.*).br",
      "headers": [
        { "key": "Content-Encoding", "value": "br" }
      ]
    }
  ]
}
